using std.character.isNumeric;
using std.int.parseInt;

public interface Stringable {
    String toString();
}

public void print(String str){
    for(uint i = 0; i < str.length; i++){
        /* do some system call on `str.at(i)` */
    }
}

public void println(String str){
    inline print(str);
    /* do some system call on '\n' */
}

public void printf(String fStr, Stringable[] values) {

    String[] chunks = fStr.split('$');

    for(uint i = 0; i < chunks.size - 1; i++){ // guarantees we have at least more than one chunk

        alias currentChunk = chunks[i];
        alias nextChunk = chunks[i + 1];

        if(isNumeric(nextChunk.at(0))){

            uint endIdx = 0;

            for(uint i = 1; i < nextChunk.length; i++){
                if(isNumeric(nextChunk.at(i))){
                    endIdx += 1;
                } else {
                    break;
                }
            }

            uint arrayIdx = parseInt(nextChunk.substr(0, endIdx + 1));

            inline print(currentChunk.concat(values[arrayIdx].toString()));

        } else {
            inline print(currentChunk.concat("$"));
        }

    }

    inline print(chunks[chunks.size - 1]);

}

public void printfln(String fStr, Stringable[] values){
    inline printf(fStr, values);
    /* do some system call on '\n' */
}