using std.print;
using std.math;

// using define makes it publically accessable
define class Point2D {

    double x;
    double y;

    Point2D(double x, double y){
        this.x = x;
        this.y = y;
    }

    Point2D(){
        this.x = 0.0f;
        this.y = 0.0f;
    }

    double getX(){
        return this.x;
    }

    double getY(){
        return this.y;
    }

}

define class NamedPoint2D {

    String name;
    expose Point2D point2D; 

    /*  the keyword 'expose' allows NamedPoint2D
    *   to expose all of Point2D's public methods
    *   as its own.
    */

    NamedPoint2D(String name, Point2D? point2D){
        this.name = name;
        
        if(point2D){
            this.point2D = point2D;
        } else {
            this.point2D = new Point2D();
        }
    }

    String getName(){
        return this.name;
    }

}

void main(){

    Point2D pointA = new Point2D(3.0, 4.0);
    Point2D pointB = new Point2D();
    
    NamedPoint2D midPoint = new NamedPoint2D(
        "Midpoint", 
        new Point2D(
            (pointB.getX() - pointA.getX()), 
            (pointB.getY() - pointA.getY())
        )
    );

    NamedPoint2D originPoint = new NamedPoint2D("Origin");

    println(
        "The midpoint named '" + midPoint.getName()
        + "' between Point A and B is: ("
        + midPoint.getX() + ", "
        + midPoint.getY() + ")."
    );

    println(
        "The orgin point name '" + originPoint.getName()
        + "' is located at (" + originPoint.getX()
        + ", " + originPoint.getY()
        + ")."
    );

}